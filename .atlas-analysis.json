  "keyFeatures": [
    "Universal catalog for data and AI assets",
    "Multi-format support (Delta Lake, Iceberg, Hudi, Parquet)",
    "Multi-engine compatibility (DuckDB, Spark, Trino)",
    "Three-level namespace (catalog.schema.table)",
    "Unified governance and permissions",
    "ML model registry and versioning",
    "REST API with OpenAPI specification",
    "CLI and UI for catalog management",
    "AI framework integrations (LangChain, LlamaIndex, OpenAI)",
    "Apache Hive and Iceberg API compatibility"
  ],
  "publicApiSurface": [
    "POST /catalogs - Create catalog",
    "GET /catalogs - List catalogs",
    "GET /catalogs/{name} - Get catalog",
    "PATCH /catalogs/{name} - Update catalog",
    "DELETE /catalogs/{name} - Delete catalog",
    "POST /schemas - Create schema",
    "GET /schemas - List schemas",
    "GET /schemas/{full_name} - Get schema",
    "POST /tables - Create table",
    "GET /tables - List tables",
    "GET /tables/{full_name} - Get table",
    "POST /volumes - Create volume",
    "GET /volumes - List volumes",
    "POST /functions - Create function",
    "GET /functions - List functions",
    "POST /models - Create registered model",
    "GET /models - List registered models",
    "POST /model-versions - Create model version",
    "GET /temporary-table-credentials - Generate temporary credentials",
    "POST /permissions - Manage permissions",
    "bin/uc catalog - Catalog CLI commands",
    "bin/uc schema - Schema CLI commands",
    "bin/uc table - Table CLI commands",
    "bin/uc volume - Volume CLI commands",
    "bin/uc function - Function CLI commands",
    "bin/uc model - Model CLI commands",
    "unitycatalog-ai Python package - AI integrations",
    "UnityCatalogClient - Java/Python SDK"
  ]
